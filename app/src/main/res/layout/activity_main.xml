<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E1116"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitulo"
        android:textColor="#9AA4B2"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/grabar"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            app:icon="@drawable/ic_rec"
            app:iconSize="26dp"
            app:iconGravity="textStart"
            app:cornerRadius="36dp"
            app:backgroundTint="#E23B3B" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFlyer"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/portada_corta"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:strokeColor="#3A4250"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtFlyer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/portada_ninguna"
        android:textColor="#6B7482"
        android:textSize="12sp"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/listo"
        android:textColor="#9AA4B2"
        android:textSize="13sp"
        android:layout_marginTop="10dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E2430"
        android:layout_marginVertical="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/mis_grabaciones"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/actualizar"
            android:textColor="#4C9AFF"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sin_grabaciones"
        android:textColor="#6B7482"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listRecordings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

</LinearLayout>
